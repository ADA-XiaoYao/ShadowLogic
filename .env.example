# ShadowLogic Environment Variables Configuration Example
# Copy this file to .env and fill in your actual configuration

# OpenAI API Key
# Get it from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Specify OpenAI Model
# Defaults to gpt-4.1-mini
OPENAI_MODEL=gpt-4.1-mini

# Optional: Set log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Optional: Set data storage directory
DATA_DIR=.shadowlogic_data
